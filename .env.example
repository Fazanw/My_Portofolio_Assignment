# ============================================================
# .env.example — SAFE TO PUSH TO GITHUB (no real credentials)
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

FLASK_ENV=production
PORT=5000
GRAFANA_PASSWORD=your_secure_password_here

# Grafana Cloud (for remote metrics push)
# Get these from: grafana.com -> My Account -> Stack -> Details
GRAFANA_REMOTE_WRITE_URL=https://prometheus-prod-xx.grafana.net/api/prom/push
GRAFANA_USER_ID=your_user_id
GRAFANA_API_KEY=your_api_key
